[resource type="Shader" id=2]
shader_type canvas_item;

uniform vec4 glow_color : hint_color = vec4(1.0, 0.2, 0.2, 1.0);
uniform float inner_radius = 0.1;
uniform float outer_radius = 0.85;

void fragment() {
    vec2 centered = UV - vec2(0.5);
    float dist = length(centered);
    float t = smoothstep(outer_radius, inner_radius, dist);
    float a = pow(t, 1.2) * 1.6;
    a = clamp(a, 0.0, 1.0);
    COLOR = vec4(glow_color.rgb * 1.2, a * glow_color.a);
}
