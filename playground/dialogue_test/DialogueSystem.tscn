[sub_resource type="GDScript" id="GDScript_ewl02"]
script/source = "extends CanvasLayer

# --- 节点引用 ---
@onready var label = $Control/Background/RichTextLabel
@onready var audio_player = $Control/AudioStreamPlayer

# --- 参数设置 ---
@export var type_speed: float = 0.05       # 正常打字速度
@export var pitch_min: float = 0.95        # 随机音调下限
@export var pitch_max: float = 1.1         # 随机音调上限

var is_typing: bool = false                # 标记当前是否正在打字

func _ready():
	# 初始化：清空文字
	label.bbcode_enabled = true
	label.text = \"\"
	
	# 测试：1秒后开始对话
	await get_tree().create_timer(1.0).timeout
	start_dialogue(\"[shake rate=20 level=10]Hello, texteffect is here![/shake] [color=red]Test！[/color]\")

# --- 核心函数：开始对话 ---
func start_dialogue(content: String):
	if is_typing: return # 防止重叠触发
	
	is_typing = true
	label.text = content
	label.visible_characters = 0
	
	# 获取不包含 BBCode 标签的纯文本
	var pure_text = label.get_parsed_text()
	var total_chars = pure_text.length()
	
	for i in range(total_chars + 1):
		# 如果在循环中途被外部中断（比如跳过对话），直接退出
		if not is_typing: break
		
		label.visible_characters = i
		
		# 只有跳出新字符时才播放声音
		if i > 0 and i <= total_chars:
			var current_char = pure_text[i-1]
			
			# 过滤空格和换行符，不为它们播音
			if current_char != \" \" and current_char != \"\\n\":
				_play_voice_snappy()
			
			# 处理停顿感
			var wait_time = type_speed
			# 遇到标点符号，停顿时间加长
			if current_char in [\"，\", \"。\", \"！\", \"？\", \"…\", \",\", \".\", \"!\", \"?\"]:
				wait_time = type_speed * 5
				
			await get_tree().create_timer(wait_time).timeout
	
	is_typing = false
	audio_player.stop() # 确保文字出完后声音立即停止

# --- 辅助函数：清脆的播音逻辑 ---
func _play_voice_snappy():
	if audio_player.stream:
		# 强制重置声音进度，解决延迟和重叠问题
		audio_player.stop()
		
		# 随机微调音调，让“哒哒哒”听起来不机械
		audio_player.pitch_scale = randf_range(pitch_min, pitch_max)
		
		audio_player.play()
"

